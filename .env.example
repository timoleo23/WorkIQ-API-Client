# =============================================================================
# Work IQ API Demonstrator — environment configuration
# =============================================================================
# Copy this file to ".env.local" and fill in your own values.
# .env.local is git-ignored — NEVER commit real tenant or client IDs.
#
# Both variables are optional: if left empty, the app prompts the user to enter
# them on the /settings page at runtime (values are then persisted in the
# browser's localStorage — nothing is sent to a backend).
# =============================================================================

# Microsoft Entra tenant where your app registration lives.
# Use "common" / "organizations" for multi-tenant, or your tenant GUID/domain
# (e.g. "contoso.onmicrosoft.com" or "a1b2c3d4-...") for single-tenant.
NEXT_PUBLIC_ENTRA_TENANT_ID=common

# Application (client) ID of the Entra SPA app registration created for this app.
# See README.md → "Entra app registration" for the step-by-step.
NEXT_PUBLIC_ENTRA_CLIENT_ID=

# Work IQ service base URL. Default is the public Microsoft endpoint — only
# change this if Microsoft documents a regional / sovereign cloud variant.
NEXT_PUBLIC_WORKIQ_BASE_URL=https://workiq.svc.cloud.microsoft
